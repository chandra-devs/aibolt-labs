---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DyntLab from '../../components/DyntLab.astro';
const geometries = [
  ['Square', 'A regular rectilinear field for structured surfaces.'],
  ['Connected hexagon', 'A continuous honeycomb with shared visual adjacency.'],
  ['Circle', 'Separated radial cells that clarify wave-front curvature.'],
  ['Interlocked diamond', 'Offset cells that emphasize directional propagation.'],
];
---

<BaseLayout title="DYNT Kinetic — Physical interface response" description="Kinetic gives existing interfaces bounded directional tilt, click-origin cell waves, impact, drift, and semantic content response.">
  <section class="page-hero"><div class="shell"><div class="breadcrumb"><a href="/dynt">DYNT</a> / Kinetic</div><div class="eyebrow eyebrow-blue">@dynt/kinetic</div><h1 class="page-title">Response begins where contact happens.</h1><p class="lead">Kinetic resolves the nearest owned surface, compresses the near edge, raises the far edge, and sends circular turbulent waves outward from the actual input point.</p><div class="hero-actions"><a class="button" href="https://www.npmjs.com/package/@dynt/kinetic">Install from npm ↗</a><a class="button button-quiet" href="https://github.com/aibolt/dynt/tree/main/packages/kinetic">Source ↗</a></div></div></section>
  <section class="section"><div class="shell"><div class="eyebrow eyebrow-blue">Live Kinetic lab</div><h2 class="section-title">Move to an edge. Click anywhere. Change the cells.</h2><p class="section-copy">The pointer position controls bounded directional tilt. Clicks create cell geometry only for the active wave and propagate through semantic reactors by distance.</p><div style="margin-top: 28px"><DyntLab initialMode="kinetic" /></div></div></section>
  <section class="section section-divider"><div class="shell"><div class="eyebrow">Cell geometry</div><h2 class="section-title">One wave model across four renderers.</h2><div class="grid-4">{geometries.map(([name, description], index) => <article class="card card-blue"><span class="number">{String(index + 1).padStart(2, '0')}</span><h3>{name}</h3><p>{description}</p></article>)}</div></div></section>
  <section class="section-tight"><div class="shell grid-3"><article class="card"><h3>Directional plate response</h3><p>The near overflow contracts while the far edge extends. Application-owned transforms remain untouched.</p></article><article class="card card-blue"><h3>Circular turbulent waves</h3><p>Speed, thickness, recovery, intensity, turbulence, growth, and overflow remain independently configurable.</p></article><article class="card"><h3>Content response</h3><p>Locally owned semantic groups lift, rebound, and settle in distance order without changing their meaning.</p></article></div></section>
</BaseLayout>
