---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Videos — AIBolt Labs" description="AIBolt Labs demonstrations, engineering walkthroughs, and project releases on YouTube.">
  <section class="page-hero"><div class="shell"><div class="eyebrow eyebrow-blue">Videos</div><h1 class="page-title">Watch systems move from idea to working interface.</h1><p class="lead">The AIBolt Labs channel is live. Our first production series will document DYNT from architecture through real integration.</p><div class="hero-actions"><a class="button" href="https://www.youtube.com/@AiBoltLabs">Visit @AiBoltLabs on YouTube ↗</a></div></div></section>
  <section class="section">
    <div class="shell">
      <div class="panel media-banner"><div class="media-banner-content"><div class="eyebrow">First series</div><h2 class="section-title">DYNT: interfaces that construct and respond.</h2><p class="section-copy">Planned episodes cover the system overview, Formation choreography, Kinetic cells and waves, and framework integration.</p></div></div>
      <div class="grid-3 section-tight">
        <article class="card"><span class="number">01 · PLANNED</span><h3>DYNT system overview</h3><p>Why Formation and Kinetic are independent, and when to combine them.</p></article>
        <article class="card"><span class="number">02 · PLANNED</span><h3>Formation deep dive</h3><p>Viewport travel, profile sequencing, line construction, and withdrawal.</p></article>
        <article class="card card-blue"><span class="number">03 · PLANNED</span><h3>Kinetic deep dive</h3><p>Directional tilt, cell geometries, turbulence, and content response.</p></article>
      </div>
    </div>
  </section>
</BaseLayout>
