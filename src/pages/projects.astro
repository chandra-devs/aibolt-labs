---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projects — AIBolt Labs" description="Open-source systems and practical interface experiments from AIBolt Labs.">
  <section class="page-hero"><div class="shell"><div class="eyebrow">Projects</div><h1 class="page-title">Systems built to become useful beyond the lab.</h1><p class="lead">Our projects begin as focused experiments and mature into documented, independently usable tools.</p></div></section>
  <section class="section">
    <div class="shell grid-2">
      <article class="panel panel-body">
        <div class="eyebrow">Flagship open-source project</div>
        <h2 class="section-title">DYNT</h2>
        <p class="section-copy">A framework-neutral interface system with independently installable Formation and Kinetic engines.</p>
        <div class="hero-actions"><a class="button" href="/dynt">Explore DYNT</a><a class="button button-quiet" href="https://github.com/aibolt/dynt">Source code ↗</a></div>
      </article>
      <article class="panel media-banner"><div class="media-banner-content"><div class="eyebrow">In development</div><h2 class="section-title">More from AIBolt Labs.</h2><p class="section-copy">Future projects will join this catalogue with the same emphasis on transparent engineering, live proof, and practical adoption.</p></div></article>
    </div>
  </section>
</BaseLayout>
