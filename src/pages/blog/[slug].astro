---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props { post: CollectionEntry<'blog'> }
const { post } = Astro.props;
const { Content } = await render(post);
const published = post.data.published.toLocaleDateString('en', { month: 'long', day: 'numeric', year: 'numeric' });
---

<BaseLayout title={`${post.data.title} — AIBolt Labs`} description={post.data.description}>
  <article>
    <header class="page-hero"><div class="shell"><div class="breadcrumb"><a href="/blog">Journal</a> / {post.data.category}</div><div class="eyebrow">{post.data.category} · {published}</div><h1 class="page-title">{post.data.title}</h1><p class="lead">{post.data.description}</p></div></header>
    <div class="section"><div class="shell prose"><Content /></div></div>
  </article>
  <script type="application/ld+json" is:inline set:html={JSON.stringify({ '@context': 'https://schema.org', '@type': 'TechArticle', headline: post.data.title, description: post.data.description, datePublished: post.data.published.toISOString(), publisher: { '@type': 'Organization', name: 'AIBolt Labs' }, mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).href })} />
</BaseLayout>
