---
interface Props {
  compact?: boolean;
  viewportFlow?: boolean;
  initialMode?: 'formation' | 'kinetic' | 'combined';
}

const { compact = false, viewportFlow = false, initialMode = 'combined' } = Astro.props;
---

<section class:list={['dynt-lab', { 'dynt-lab-compact': compact }]} data-dynt-lab data-viewport-flow={viewportFlow ? 'true' : 'false'} data-initial-mode={initialMode}>
  <div class="dynt-lab-toolbar" data-dynt-ignore>
    <div class="dynt-mode-switch" aria-label="DYNT engine mode">
      <button type="button" data-dynt-mode="formation" aria-pressed="false">Formation</button>
      <button type="button" data-dynt-mode="kinetic" aria-pressed="false">Kinetic</button>
      <button type="button" data-dynt-mode="combined" aria-pressed="true">Combined</button>
    </div>
    <div class="dynt-lab-status"><span></span> Live package runtime</div>
  </div>

  <div class="dynt-live-stage" data-dynt-stage>
    <article class="dynt-live-surface" data-dynt-cell-shape="hexagon">
      <div data-dynt-reactor><span class="surface-icon">01</span><h3>Construct</h3><p>Interfaces form through reversible geometry.</p></div>
    </article>
    <article class="dynt-live-surface" data-dynt-cell-shape="circle">
      <div data-dynt-reactor><span class="surface-icon surface-icon-blue">02</span><h3>Respond</h3><p>Surfaces react at the point of contact.</p></div>
    </article>
    <article class="dynt-live-surface" data-dynt-cell-shape="diamond">
      <div data-dynt-reactor><span class="surface-icon">03</span><h3>Integrate</h3><p>One boundary enhances existing HTML.</p></div>
    </article>
    {!compact && (
      <article class="dynt-live-surface" data-dynt-cell-shape="square">
        <div data-dynt-reactor><span class="surface-icon surface-icon-blue">04</span><h3>Remain semantic</h3><p>Motion stays separate from accessible meaning.</p></div>
      </article>
    )}
  </div>

  <div class="dynt-lab-controls" data-dynt-ignore>
    <label>
      <span>Formation profile</span>
      <select data-dynt-profile>
        <option value="line-push">Line Push</option>
        <option value="line-rise">Line Rise</option>
        <option value="arc-trace">Arc Trace</option>
        <option value="squircle-sweep">Squircle Sweep</option>
        <option value="chamfer-fold">Chamfer Fold</option>
        <option value="magnetic-segment">Magnetic Segment</option>
        <option value="radial-compass">Radial Compass</option>
        <option value="aperture-iris">Aperture Iris</option>
        <option value="elastic-membrane">Elastic Membrane</option>
      </select>
    </label>
    <div class="geometry-control" aria-label="Kinetic cell geometry">
      <span>Cell geometry</span>
      <div>
        <button type="button" data-dynt-geometry="square" aria-label="Square cells">□</button>
        <button type="button" data-dynt-geometry="hexagon" aria-label="Hexagon cells">⬡</button>
        <button type="button" data-dynt-geometry="circle" aria-label="Circular cells">○</button>
        <button type="button" data-dynt-geometry="diamond" aria-label="Interlocked cells">◇</button>
      </div>
    </div>
    <div class="lab-actions">
      <button type="button" class="button button-small button-quiet" data-dynt-withdraw>Withdraw</button>
      <button type="button" class="button button-small" data-dynt-replay>Replay formation</button>
      {!compact && <button type="button" class="button button-small button-outline" data-dynt-add>Add surface</button>}
    </div>
  </div>
</section>

<script>
  import { createFormation } from '@dynt/formation';
  import { createKinetic, kineticPresets } from '@dynt/kinetic';

  const labs = document.querySelectorAll<HTMLElement>('[data-dynt-lab]');

  for (const lab of labs) {
    const stage = lab.querySelector<HTMLElement>('[data-dynt-stage]');
    if (!stage || lab.dataset.ready === 'true') continue;
    lab.dataset.ready = 'true';

    let profile = 'line-push';
    let mode = 'combined';
    let formation: ReturnType<typeof createFormation> | null = null;
    let kinetic: ReturnType<typeof createKinetic> | null = null;

    const mountFormation = () => {
      if (formation) return formation;
      const useViewportFlow = lab.dataset.viewportFlow === 'true' && ['line-push', 'line-rise'].includes(profile);
      formation = createFormation({
        root: stage,
        selector: '.dynt-live-surface',
        profile,
        observe: true,
        viewportFlow: useViewportFlow ? { duration: 1080, lineLength: 720, overrun: 34, stagger: 125 } : false,
        tokens: {
          duration: 380,
          easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
          fillColor: 'rgb(10 11 13 / 0.96)',
          lineColor: '#ffbf00',
          lineWidth: '1px',
          overflow: 13,
        },
      });
      return formation;
    };

    const mountKinetic = () => {
      if (kinetic) return kinetic;
      kinetic = createKinetic({
        root: stage,
        selector: '.dynt-live-surface',
        observe: true,
        ...kineticPresets.structural,
        cells: { ...kineticPresets.structural.cells, shape: 'hexagon', size: [38, 30, 24] },
        effects: { ...kineticPresets.structural.effects, content: true, tilt: true, wave: true },
        motion: { ...kineticPresets.structural.motion, maxTilt: 1.35, response: 0.2 },
        flow: { ...kineticPresets.structural.flow, turbulence: 0.42, overflow: 13, multi: true, maxWaves: 3 },
      });
      return kinetic;
    };

    const setMode = (nextMode: string) => {
      mode = nextMode;
      lab.querySelectorAll<HTMLButtonElement>('[data-dynt-mode]').forEach((button) => {
        button.setAttribute('aria-pressed', String(button.dataset.dyntMode === mode));
      });
      if (mode === 'formation') {
        kinetic?.destroy();
        kinetic = null;
        mountFormation().form();
      } else if (mode === 'kinetic') {
        formation?.destroy();
        formation = null;
        mountKinetic().resume();
      } else {
        mountFormation().form();
        mountKinetic().resume();
      }
    };

    const replayFormation = () => {
      const controller = mountFormation();
      const targets = stage.querySelectorAll('.dynt-live-surface').length;
      const completed = new Set<Element>();
      const unsubscribe = controller.subscribe(({ element, phase }) => {
        if (phase !== 'unformed') return;
        completed.add(element);
        if (completed.size >= targets) {
          unsubscribe();
          requestAnimationFrame(() => controller.form());
        }
      });
      controller.withdraw();
    };

    lab.querySelectorAll<HTMLButtonElement>('[data-dynt-mode]').forEach((button) => {
      button.addEventListener('click', () => setMode(button.dataset.dyntMode ?? 'combined'));
    });
    lab.querySelector<HTMLSelectElement>('[data-dynt-profile]')?.addEventListener('change', (event) => {
      profile = (event.currentTarget as HTMLSelectElement).value;
      formation?.destroy();
      formation = null;
      if (mode !== 'kinetic') mountFormation().form();
    });
    lab.querySelectorAll<HTMLButtonElement>('[data-dynt-geometry]').forEach((button) => {
      button.addEventListener('click', () => {
        const shape = button.dataset.dyntGeometry ?? 'hexagon';
        stage.querySelectorAll<HTMLElement>('.dynt-live-surface').forEach((surface) => { surface.dataset.dyntCellShape = shape; });
        lab.querySelectorAll('[data-dynt-geometry]').forEach((item) => item.removeAttribute('data-active'));
        button.dataset.active = 'true';
        kinetic?.refresh();
      });
    });
    lab.querySelector<HTMLButtonElement>('[data-dynt-withdraw]')?.addEventListener('click', () => mountFormation().withdraw());
    lab.querySelector<HTMLButtonElement>('[data-dynt-replay]')?.addEventListener('click', replayFormation);
    lab.querySelector<HTMLButtonElement>('[data-dynt-add]')?.addEventListener('click', () => {
      const next = document.createElement('article');
      next.className = 'dynt-live-surface';
      next.dataset.dyntCellShape = 'circle';
      next.innerHTML = '<div data-dynt-reactor><span class="surface-icon">NEW</span><h3>Discovered</h3><p>Observed after the engines were already running.</p></div>';
      stage.append(next);
    });

    setMode(lab.dataset.initialMode ?? 'combined');
  }
</script>

<style is:global>
  .dynt-lab { --dynt-kinetic-color: #64c6ff; overflow: hidden; border: 1px solid rgba(255,191,0,.42); border-radius: 16px; background: rgba(7,8,9,.96); box-shadow: 0 28px 90px rgba(0,0,0,.5); }
  .dynt-lab-toolbar { min-height: 60px; display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 10px 14px; border-bottom: 1px solid rgba(255,255,255,.1); }
  .dynt-mode-switch { display: inline-flex; padding: 4px; border: 1px solid rgba(255,255,255,.12); border-radius: 9px; background: #070809; }
  .dynt-mode-switch button { min-height: 34px; padding: .35rem .8rem; border: 0; border-radius: 6px; background: transparent; color: #9f9fa5; cursor: pointer; font-size: .76rem; }
  .dynt-mode-switch button[aria-pressed="true"] { background: rgba(255,191,0,.13); color: #ffcf39; box-shadow: inset 0 0 0 1px rgba(255,191,0,.55); }
  .dynt-lab-status { display: flex; align-items: center; gap: 7px; color: #8e8e94; font-size: .7rem; }
  .dynt-lab-status span { width: 7px; height: 7px; border-radius: 50%; background: #ffbf00; box-shadow: 0 0 12px rgba(255,191,0,.8); }
  .dynt-live-stage { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 16px; min-height: 410px; padding: 28px; align-content: center; background: radial-gradient(circle at 86% 80%, rgba(100,198,255,.08), transparent 30%); }
  .dynt-lab-compact .dynt-live-stage { grid-template-columns: repeat(3, minmax(0,1fr)); min-height: 320px; padding: 24px; }
  .dynt-live-surface { position: relative; min-width: 0; min-height: 160px; display: flex; align-items: flex-end; padding: 22px; border: 1px solid rgba(255,191,0,.35); border-radius: 10px; background: linear-gradient(145deg, rgba(255,191,0,.055), rgba(255,255,255,.018)); isolation: isolate; cursor: crosshair; }
  .dynt-live-surface > [data-dynt-reactor] { position: relative; z-index: 2; }
  .dynt-live-surface h3 { margin: .55rem 0 .25rem; font-size: 1rem; }
  .dynt-live-surface p { margin: 0; max-width: 210px; color: #a1a1aa; font-size: .78rem; line-height: 1.5; }
  .surface-icon { display: inline-flex; color: #ffbf00; font: 700 .7rem ui-monospace, SFMono-Regular, Menlo, monospace; letter-spacing: .14em; }
  .surface-icon-blue { color: #64c6ff; }
  .dynt-lab-controls { display: grid; grid-template-columns: minmax(150px,.7fr) 1fr auto; align-items: end; gap: 18px; padding: 16px 18px 18px; border-top: 1px solid rgba(255,255,255,.1); }
  .dynt-lab-controls label, .geometry-control { display: grid; gap: 6px; color: #8f8f96; font-size: .68rem; }
  .dynt-lab-controls select { width: 100%; min-height: 38px; padding: 0 .7rem; border: 1px solid rgba(255,255,255,.14); border-radius: 7px; background: #090a0b; }
  .geometry-control > div, .lab-actions { display: flex; flex-wrap: wrap; gap: 7px; }
  .geometry-control button { width: 38px; height: 38px; border: 1px solid rgba(255,255,255,.13); border-radius: 7px; background: #090a0b; color: #d4d4d8; cursor: pointer; }
  .geometry-control button:hover, .geometry-control button[data-active="true"] { border-color: #64c6ff; color: #64c6ff; background: rgba(100,198,255,.08); }
  .lab-actions { justify-content: flex-end; }
  @media (max-width: 820px) { .dynt-lab-compact .dynt-live-stage, .dynt-live-stage { grid-template-columns: 1fr; min-height: auto; } .dynt-lab-controls { grid-template-columns: 1fr; align-items: stretch; } .lab-actions { justify-content: flex-start; } }
  @media (max-width: 520px) { .dynt-lab-toolbar { align-items: flex-start; flex-direction: column; } .dynt-mode-switch { width: 100%; } .dynt-mode-switch button { flex: 1; } .dynt-live-stage { padding: 18px; } }
</style>
